---

<Layout
  title="Media"
  description="Video and audio samples from Second Wind Music Productions."
>

  <section class="page-hero">
    <div class="container">
      <h1>Media</h1>
      <p>Performance videos, audio recordings, and mastering samples from our productions.</p>
    </div>
  </section>

  <!-- Video Section -->
  <section class="section">
    <div class="container">
      <h2>Performance Videos</h2>
      <p class="video-section-intro">Live performance videos captured and produced by Second Wind Music Productions.</p>
      <div class="video-grid">
        {videos.map(video => (
          <article class="video-card">
            <div class="video-embed">
              <iframe
                src={video.embedUrl}
                title={video.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <div class="video-info">
              <h3>{video.title}</h3>
              <span class="video-type">{video.type}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Audio Section -->
  <section class="section section--alt">
    <div class="container">
      <h2>Audio Recordings</h2>
      <p class="section-intro">Demo recordings and mastered tracks produced by Second Wind Music Productions.</p>
      <div class="audio-list">
        {audioClips.map(clip => (
          <div class="audio-item">
            <div class="audio-meta">
              <span class="audio-artist">{clip.artist}</span>
              <span class="audio-title">"{clip.title}"</span>
              <span class="audio-type">{clip.type}</span>
            </div>
            <div class="audio-player">
              {clip.src ? (
                <audio controls preload="none">
                  <source src={clip.src} type="audio/mpeg" />
                  Your browser does not support the audio element.
                </audio>
              ) : (
                <span class="audio-unavailable">File not available online</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Artist List -->
  <section class="section">
    <div class="container">
      <h2>Artists We've Worked With</h2>
      <p class="section-intro">
        Demo recordings, CDs, and videos for local and regional songwriters and musicians.
      </p>
      <div class="artist-list">
        {artists.map(artist => (
          <div class="artist-tag">
            {artist.url
              ? <a href={artist.url} target="_blank" rel="noopener noreferrer">{artist.name}</a>
              : <span>{artist.name}</span>
            }
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Legacy note -->
  <section class="section section--alt">
    <div class="container">
      <div class="legacy-note">
        <h3>Looking for older recordings?</h3>
        <p>
          Greg keeps an archive of past projects including recordings and videos not listed here.
          Reach out directly and he can share files on request.
        </p>
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #1a4a72 0%, #235d8f 100%);
    color: #fff;
    padding-block: 3.5rem;
  }
  .page-hero h1 { color: #fff; margin-bottom: 0.5rem; }
  .page-hero p  { color: rgba(255,255,255,0.75); font-size: 1.1rem; }

  .section-intro {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 640px;
    margin-bottom: 2.5rem;
  }

  /* White with shadow for the video section intro specifically */
  .video-section-intro {
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    font-size: 1.075rem;
    max-width: 640px;
    margin-bottom: 2.5rem;
  }

  /* --- Videos --- */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .video-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .video-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  }

  .video-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #111;
  }
  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-info {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .video-info h3  { font-size: 0.95rem; margin: 0; }
  .video-type     { font-size: 0.8rem; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; }

  /* --- Audio --- */
  .audio-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .audio-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.25rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }
  .audio-item:last-child { border-bottom: none; }
  .audio-item:nth-child(even) { background: #f8f9fb; }

  .audio-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .audio-artist { font-weight: 700; font-size: 0.95rem; color: var(--color-dark); }
  .audio-title  { font-size: 0.9rem; color: var(--color-muted); font-style: italic; }
  .audio-type   { font-size: 0.75rem; color: var(--color-brand); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }

  .audio-player audio {
    height: 36px;
    min-width: 220px;
  }
  .audio-unavailable {
    font-size: 0.8rem;
    color: #aaa;
    font-style: italic;
  }

  /* --- Artist tags --- */
  .artist-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .artist-tag {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    font-size: 0.9rem;
    transition: border-color 0.15s, background 0.15s;
  }
  .artist-tag:hover {
    border-color: var(--color-brand);
    background: #f0f7ff;
  }
  .artist-tag a {
    color: var(--color-dark);
    text-decoration: none;
  }
  .artist-tag a:hover { color: var(--color-brand); }
  .artist-tag span   { color: var(--color-dark); }

  /* --- Legacy note --- */
  .legacy-note {
    background: var(--color-surface);
    border-left: 4px solid var(--color-brand);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.5rem 2rem;
    max-width: 640px;
  }
  .legacy-note h3 { margin-bottom: 0.5rem; }
  .legacy-note p  { color: var(--color-mid); margin-bottom: 1rem; }
</style>
