---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/images/SWMLogo2Large.gif" alt="Second Wind Music Productions" width="180" height="60" />
      <p class="tagline"><em>"Makin' Silk Purses out of Silk!"</em></p>
    </div>
    <div class="footer-links">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/media">Media</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="footer-contact">
      <h3>Contact</h3>
      <p>Greg Baker<br />
        <a href="tel:7048463873">704-846-3873</a><br />
        <a href="mailto:admin@secondwindmusic.com">admin@secondwindmusic.com</a>
      </p>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} Second Wind Music Productions. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: #ccc;
    margin-top: auto;
    border-top: 3px solid var(--color-brand);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2.5rem;
    padding-block: 3rem;
  }

  .footer-brand img {
    margin-bottom: 0.75rem;
    filter: brightness(0.9);
  }

  .tagline {
    color: var(--color-gold);
    font-size: 0.9rem;
    margin: 0;
  }

  .footer-links h3,
  .footer-contact h3 {
    color: var(--color-gold);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer-links a,
  .footer-contact a {
    color: #bbb;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.15s;
  }
  .footer-links a:hover,
  .footer-contact a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-contact p {
    font-size: 0.95rem;
    line-height: 1.9;
    margin: 0;
  }

  .footer-bottom {
    border-top: 1px solid #333;
    padding-block: 1rem;
  }
  .footer-bottom p {
    text-align: center;
    font-size: 0.8rem;
    color: #666;
    margin: 0;
  }
</style>
